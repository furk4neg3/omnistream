{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QueryResponse",
  "type": "object",
  "required": [
    "query",
    "tenant_id",
    "results",
    "timing_ms",
    "used_rag",
    "answer_status",
    "citations"
  ],
  "properties": {
    "query": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "answer": {
      "type": ["string", "null"]
    },
    "short_summary": {
      "type": ["string", "null"]
    },
    "answer_status": {
      "type": "string",
      "enum": ["grounded", "insufficient_context", "fallback"]
    },
    "confidence": {
      "type": ["string", "null"],
      "enum": ["low", "medium", "high", null]
    },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["chunk_id", "ticket_id", "reason"],
        "properties": {
          "chunk_id": {
            "type": "string"
          },
          "ticket_id": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "used_rag": {
      "type": "boolean"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "chunk_id",
          "ticket_id",
          "score",
          "text",
          "metadata"
        ],
        "properties": {
          "chunk_id": {
            "type": "string"
          },
          "ticket_id": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "text": {
            "type": "string"
          },
          "metadata": {
            "type": "object",
            "required": ["severity", "product", "timestamp"],
            "properties": {
              "severity": {
                "type": "string"
              },
              "product": {
                "type": "string"
              },
              "timestamp": {
                "type": "string",
                "format": "date-time"
              },
              "customer_tier": {
                "type": "string"
              },
              "source": {
                "type": "string"
              },
              "tenant_id": {
                "type": "string"
              },
              "event_type": {
                "type": ["string", "null"]
              },
              "record_id": {
                "type": ["string", "null"]
              },
              "source_payload_id": {
                "type": ["string", "null"]
              },
              "router_label": {
                "type": ["string", "null"]
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "timing_ms": {
      "type": "object",
      "required": ["retrieval"],
      "properties": {
        "retrieval": {
          "type": "number"
        },
        "generation": {
          "type": ["number", "null"]
        },
        "total": {
          "type": "number"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
