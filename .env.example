# OmniStream local configuration template.
# Copy this file to .env for local overrides.
# Keep real secrets out of git.

APP_NAME="OmniStream Query API"
APP_VERSION=0.1.0
QUERY_API_PORT=8000

# Local data and processing defaults.
TENANT_ID=acme
EVENT_TYPES=support_ticket,customer_chat_message
EVENTS_PER_SECOND=1
MAX_EVENTS=10
POLL_INTERVAL_SECONDS=1.0
LOOP_FOREVER=true
BATCH_SIZE=32
CHUNK_SIZE_WORDS=80
CHUNK_OVERLAP_WORDS=20
SCHEMA_VERSION=v1
PROCESSING_VERSION=v1
DEPENDENCY_STATUS_MAX_AGE_SECONDS=30

# Local embedding defaults. Keep hashing-local-v1 for lightweight local runs.
INSTALL_SENTENCE_TRANSFORMERS=false
OMNISTREAM_EMBEDDING_MODEL_NAME=hashing-local-v1

# LLM RAG is opt-in. Leave disabled unless you intentionally provide a key.
ENABLE_LLM_RAG=false
LLM_MODEL_NAME=gemini-3-flash-preview
GEMINI_API_KEY=<optional-gemini-api-key>
GOOGLE_API_KEY=<optional-google-api-key>
MAX_CONTEXT_CHUNKS=5
MAX_CONTEXT_CHARS=6000
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=400

# Future cloud-oriented placeholders used by the producer config.
AWS_REGION=us-east-1
KINESIS_STREAM_NAME=omnistream-raw-events
